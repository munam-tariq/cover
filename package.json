{
  "name": "supportbase",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "install:prod": "pnpm install --prod --frozen-lockfile",
    "clean": "turbo clean && rm -rf node_modules",
    "indexnow:submit": "node scripts/submit-indexnow.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "turbo": "^2.9.16"
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.25",
      "postcss": ">=8.5.10",
      "esbuild": ">=0.28.1"
    },
    "ignoredBuiltDependencies": ["core-js"]
  }
}
