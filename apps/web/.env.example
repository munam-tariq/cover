# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL
# In development: http://localhost:3001
# In production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# PostHog product analytics (leave blank to disable)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error monitoring (leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=

# Server-side web error alerts (never expose this as NEXT_PUBLIC_)
SLACK_WEBHOOK_URL=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=

# Optional build-time source map upload
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_REALTIME_PRIVATE_ENABLED=
