{
  "name": "@chatbot/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node --watch --import tsx --import ./src/instrument.ts src/index.ts",
    "build": "tsup",
    "start": "node --import ./dist/instrument.mjs dist/index.mjs",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "reprocess-knowledge": "tsx scripts/reprocess-knowledge.ts"
  },
  "dependencies": {
    "@chatbot/db": "workspace:*",
    "@chatbot/shared": "workspace:*",
    "@mendable/firecrawl-js": "4.9.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.57.0",
    "@supabase/supabase-js": "2.88.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "openai": "^4.25.0",
    "pdf-parse": "^1.1.1",
    "resend": "^6.12.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chatbot/eslint-config": "workspace:*",
    "@chatbot/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
